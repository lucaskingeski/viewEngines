<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <title>Comidas</title>
    <style>
        body{
            font-family: Arial, sans-serif;
            background-color:#f5f5f5;
            margin:0;
            padding:0;
        }

        header{
            background:#ff6b35;
            color:white;
            padding:20px;
            text-align:center;
        }

        .container{
            display:flex;
            flex-wrap:wrap;
            justify-content:center;
            gap:20px;
            padding:30px;
        }

        .card{
            background:white;
            width:250px;
            border-radius:10px;
            box-shadow:0 4px 10px rgba(0,0,0,0.1);
            overflow:hidden;
            transition:0.2s;
        }

        .card:hover{
            transform:scale(1.05);
        }

        .card img{
            width:100%;
            height:160px;
            object-fit:cover;
        }

        .card-content{
            padding:15px;
        }

        .card-content h3{
            margin:0 0 10px 0;
        }

        .card-content p{
            font-size:14px;
            color:#555;
        }
    </style>
</head>
<body>

<header>
    <h1>🍔 Comidas Deliciosas</h1>
    <p>Alguns pratos famosos</p>
</header>

<div class="container">

    <% const comidas = [
        {nome:"Hambúrguer", desc:"Hambúrguer suculento com queijo e bacon.", img:"https://images.unsplash.com/photo-1550547660-d9450f859349"},
        {nome:"Lasanha", desc:"Massa em camadas com molho e queijo.", img:"https://images.unsplash.com/photo-1619895092538-128341789043"}
    ]; %>

    <% comidas.forEach(comida => { %>
        <div class="card">
            <img src="<%= comida.img %>" alt="<%= comida.nome %>">
            <div class="card-content">
                <h3><%= comida.nome %></h3>
                <p><%= comida.desc %></p>
            </div>
        </div>
    <% }) %>

</div>

</body>
</html>