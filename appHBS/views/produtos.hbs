{{!-- view: produtos.hbs --}}
{{!-- Página simples para a rota "produtos". Espera um objeto "produtos" fornecido pelo controlador. --}}

<!doctype html>
<html lang="pt-BR">
<head>
    <meta charset="utf-8">
    <title>{{#if produtos}}{{produtos.name}} - Produto{{else}}Produtos{{/if}}</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <style>
        body { font-family: Arial, Helvetica, sans-serif; background:#f7f7f7; color:#222; margin:0; padding:20px; }
        .card { max-width:800px; margin:24px auto; background:#fff; border-radius:8px; box-shadow:0 2px 8px rgba(0,0,0,.08); overflow:hidden; display:flex; gap:20px; padding:20px; align-items:flex-start; }
        .card img { width:260px; height:260px; object-fit:cover; border-radius:6px; }
        .info { flex:1; }
        h1 { margin:0 0 8px 0; font-size:24px; }
        .price { color:#0a7; font-weight:700; margin-bottom:12px; font-size:20px; }
        p { margin:0 0 12px 0; line-height:1.4; }
        ul { margin:8px 0 12px 18px; }
        .actions { margin-top:12px; }
        .btn { background:#007bff; color:#fff; padding:10px 14px; border-radius:6px; text-decoration:none; display:inline-block; }
        .btn[disabled] { background:#aaa; }
        .meta { color:#666; font-size:13px; margin-bottom:8px; }
    </style>
</head>
<body>
    {{#if produtos}}
    <div class="card">
        {{#if produtos.image}}
            <img src="{{produtos.image}}" alt="{{produtos.name}}">
        {{else}}
            <img src="https://via.placeholder.com/260x260?text=Produto" alt="Imagem indisponível">
        {{/if}}
        <div class="info">
            <h1>{{produtos.name}}</h1>
            <div class="meta">Código: {{produtos.id}} • Categoria: {{produtos.category}}</div>
            <div class="price">R$ {{produtos.price}}</div>
            <p>{{produtos.description}}</p>

            {{#if produtos.features}}
                <strong>Principais características:</strong>
                <ul>
                    {{#each produtos.features}}
                        <li>{{this}}</li>
                    {{/each}}
                </ul>
            {{/if}}

            <div class="actions">
                {{#if produtos.available}}
                    <a class="btn" href="/comprar/{{produtos.id}}">Comprar agora</a>
                {{else}}
                    <a class="btn" disabled>Indisponível</a>
                {{/if}}
                <a style="margin-left:12px; color:#555; text-decoration:none;" href="/produtos">Voltar à lista</a>
            </div>
        </div>
    </div>
    {{else}}
    <div style="max-width:800px;margin:40px auto;background:#fff;padding:20px;border-radius:8px;box-shadow:0 2px 8px rgba(0,0,0,.06);">
        <h2>Produto não encontrado</h2>
        <p>Desculpe, não há informações sobre o produto solicitado.</p>
        <p><a href="/produtos" style="color:#007bff;">Voltar à lista de produtos</a></p>
    </div>
    {{/if}}
</body>
</html>